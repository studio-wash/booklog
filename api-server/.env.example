# https://developers.naver.com/docs/serviceapi/search/book/book.md
# Values are trimmed server-side (avoid trailing newline from copy-paste).
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Aladin Open API (TTB) — PLAN-000007, knowledge/reference/api/aladin-openapi.md
# https://docs.google.com/document/d/1mX-WxuoGs8Hy-QalhHcvuV17n50uGI2Sg_GHofgiePE/edit
ALADIN_TTB_KEY=

# Neon Postgres (production-like local). Vercel integration usually sets POSTGRES_URL.
# Either name works; pooled URL recommended.
DATABASE_URL=
# POSTGRES_URL=

# Local fallback when DATABASE_URL is empty: SQLite at api-server/data/catalog.sqlite.
# CATALOG_DB_PATH=
